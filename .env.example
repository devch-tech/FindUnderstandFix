# Required for explain_issue and get_hints (Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED — the server won't start without this token
# Get it at: https://github.com/settings/tokens → "Generate new token (classic)"
# Minimum required scope: public_repo
GITHUB_TOKEN=ghp_...

# Optional — default language if not specified (default: en)
ISSUESCOUT_DEFAULT_LANG=en
